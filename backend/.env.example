# AbuseIPDB (https://www.abuseipdb.com/account/api) — free tier requires an API key
ABUSEIPDB_API_KEY=

# Cloudflare Radar (https://developers.cloudflare.com/radar/get-started/first-request/) — free API token
CLOUDFLARE_RADAR_API_TOKEN=

# Optional: ipinfo.io key if used instead of ip-api.com for geolocation (ip-api.com needs no key)
IPINFO_API_KEY=

# Salt used to hash raw IPs before persisting (sha256(ip + salt)) — generate a long random string, never commit the real value
IP_HASH_SALT=

# Ingestion poll interval in seconds (hard-coded minimum enforced in code regardless of this value)
INGEST_POLL_INTERVAL_SECONDS=30

# Comma-separated allowed CORS origins for production (wildcard only used automatically in local dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# SQLite database file path
DATABASE_URL=sqlite:///./cyberpulse.db
